# ── Claude ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Lead Discovery ────────────────────────────────────────
# SerpAPI (https://serpapi.com) — Google Jobs + LinkedIn search
# Free tier: 100 searches/month
SERP_API_KEY=

# ── Contact Enrichment (pick one) ─────────────────────────
# Hunter.io — free tier: 25 searches/month
HUNTER_API_KEY=

# Apollo.io — free tier: 50 exports/month
APOLLO_API_KEY=

# ── Your Pitch ────────────────────────────────────────────
SENDER_NAME=Your Name
SENDER_ROLE=Founder
WEBSITE_URL=https://yoursite.com
PITCH_PDF_URL=https://drive.google.com/your-pitch.pdf
CAL_LINK=https://cal.com/yourname/discovery

# ── Gmail ─────────────────────────────────────────────────
# Use App Password (NOT your main password)
# Get one at: https://myaccount.google.com/apppasswords
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── LinkedIn DM Automation (optional) ─────────────────────
# Warning: Use sparingly — max 20 DMs/day
LINKEDIN_EMAIL=you@email.com
LINKEDIN_PASSWORD=
